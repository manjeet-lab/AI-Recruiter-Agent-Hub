# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1256, check PIPFILE and PIPFILE.LOCK into git.
#   However, if you're building something that is not a package, you might ignore it:
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains exact versions.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains exact versions.
#pdm.lock

# venv
#   Use of shared virtualenvs is strongly recommended
.venv/
venv/
ENV/
env/

# spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# Streamlit config (custom credentials, but config.toml can be committed if user-defined)
.streamlit/secrets.toml

